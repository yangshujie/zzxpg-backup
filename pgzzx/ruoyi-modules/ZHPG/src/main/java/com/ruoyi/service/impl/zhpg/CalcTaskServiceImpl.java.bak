    @Override
    public Page<CalcTask> selectTaskPage(Page<?> page, CalcTask query) {
        QueryWrapper<CalcTask> wrapper = new QueryWrapper<>();
        if (query != null) {
            wrapper.like(StringUtils.isNotBlank(query.getTaskName()), "task_name", query.getTaskName());
            wrapper.eq(query.getCalcFlowTemplateId() != null, "calc_flow_template_id", query.getCalcFlowTemplateId());
            wrapper.eq(StringUtils.isNotBlank(query.getRunStatus()), "run_status", query.getRunStatus());
            wrapper.eq(StringUtils.isNotBlank(query.getCurrentStage()), "current_stage", query.getCurrentStage());
        }
        wrapper.orderByDesc("create_time");
        return baseMapper.selectPage((Page<CalcTask>) page, wrapper);
    }

    @Override
    public CalcTask selectTaskDetail(Long id) {
        CalcTask task = baseMapper.selectById(id);
        if (task == null) {
            return null;
        }
        QueryWrapper<CalcTaskStageLog> wrapper = new QueryWrapper<>();
        wrapper.eq("calc_task_id", id).orderByAsc("stage_order");
        task.setStageLogs(stageLogMapper.selectList(wrapper));
        return task;
    }

    @Override
    public void handleXxlJobCallback(Long taskId, boolean success, String resultJson) {
        handleXxlJobCallbackWithReport(taskId, success, resultJson, null, null, null);
    }

    @Override
    public void handleXxlJobCallbackWithReport(Long taskId, boolean success, String resultJson,
                                               String reportUrl, String wordUrl, String wpsUrl) {
        if (taskId == null) {
            throw new ServiceException("taskId is required");
        }
        CalcTask task = baseMapper.selectById(taskId);
        if (task == null) {
            throw new ServiceException("calc task not found: " + taskId);
        }

        JSONObject callbackPayload = buildCallbackPayload(resultJson, reportUrl, wordUrl, wpsUrl);
        UpdateWrapper<CalcTask> uw = new UpdateWrapper<>();
        uw.eq("id", taskId)
                .set("comprehensive_async_state", success ? "SUCCESS" : "FAIL")
                .set("comprehensive_async_json", callbackPayload.toJSONString())
                .set("update_by", SecurityUtils.getUsername())
                .set("update_time", new Date());
        baseMapper.update(null, uw);
    }

    @Override
    public CalcTaskAsyncResult getTaskStatus(Long taskId) {
        CalcTask task = baseMapper.selectById(taskId);
        if (task == null) {
            throw new ServiceException("calc task not found: " + taskId);
        }

        CalcTaskAsyncResult result = new CalcTaskAsyncResult();
        result.setTaskId(task.getId());
        result.setTaskName(task.getTaskName());
        result.setStatus(resolveAsyncTaskStatus(task));
        result.setCurrentStage(task.getCurrentStage());
        result.setProgressPercent(task.getProgressPercent());
        result.setCreateTime(task.getCreateTime());
        result.setStartTime(task.getStartTime());
        result.setEndTime(task.getEndTime());

        if ("FAILED".equalsIgnoreCase(task.getRunStatus())) {
            result.setErrorMessage(extractErrorMessage(task.getResultSummaryJson()));
        } else if ("FAIL".equalsIgnoreCase(task.getComprehensiveAsyncState())) {
            result.setErrorMessage(extractErrorMessage(task.getComprehensiveAsyncJson()));
        } else {
            Object payload = parseJsonText(task.getResultSummaryJson());
            if (payload == null) {
                payload = parseJsonText(task.getComprehensiveAsyncJson());
            }
            result.setResult(payload);
        }
        return result;
    }

    @Override
    public CalcTask run(CalcExecutionRequest request) {
        CalcFlowTemplate template = calcFlowTemplateService.selectTemplateDetail(request.getCalcFlowTemplateId());
        if (template == null) {
            throw new ServiceException("calc flow template not found");
        }
        if (!"PUBLISHED".equals(template.getStatus()) && !"TESTING".equals(template.getStatus())) {
            throw new ServiceException("only published or testing template can be executed");
        }
        Long indicatorSystemId = request.getIndicatorSystemId();
        if (indicatorSystemId == null) {
            throw new ServiceException("ÚÅê¯üàÕ»ÜþÇ╣µ░¡Õ»ÜÚÅìÕøªþÂïþ╗»õ╝Öþ┤░þÆü´╝äþò╗Õ¿┤õ¢║Ôû╝Õª»Ôäâµ¥ÿµÂôÕÂçþ▓ªþÇ╣µ░¡Õ»ÜÚÅìÕøªþÂïþ╗»õ╝Öþ┤ØþÆçÕ│░µ╣¬ÚìÖµêúµìúþÆü´╝äþò╗þÆçÚöïþ£░µÂô¯àØþ┤ÂÚìÅ?indicatorSystemId");
        }
        EvalIndicatorSystem indicatorSystem = indicatorSystemService.getById(indicatorSystemId);
        if (indicatorSystem == null) {
            throw new ServiceException("indicator system not found");
        }

        JSONObject configRoot = parseConfig(template.getConfigJson());
        JSONObject stages = configRoot.getJSONObject("stages");
        if (stages == null) {
            throw new ServiceException("template configJson missing stages");
        }
        JSONObject scheduleStage = stages.getJSONObject("scheduleConfig");
        JSONObject weightStage = stages.getJSONObject("weightCalc");
        JSONObject comprehensiveStage = stages.getJSONObject("comprehensiveCalc");
        JSONObject reportStage = stages.getJSONObject("reportOutput");
        JSONObject runtimePolicy = configRoot.getJSONObject("runtimePolicy");
        JSONObject scheduleConfig = stageConfig(scheduleStage);
        JSONObject weightConfig = stageConfig(weightStage);
        JSONObject comprehensiveConfig = stageConfig(comprehensiveStage);
        JSONObject reportConfig = stageConfig(reportStage);
        applyBlockAndMisfirePolicy(template.getId(), runtimePolicy);

        CalcTask task = new CalcTask();
        task.setTaskName(StringUtils.isNotBlank(request.getTaskName()) ? request.getTaskName() : buildTaskName(template));
        task.setAssessTaskId(request.getAssessTaskId());
        task.setCalcFlowTemplateId(template.getId());
        task.setTemplateSnapshotJson(template.getConfigJson());
        task.setRunStatus("RUNNING");
        task.setCurrentStage("SCHEDULE_CONFIG");
        task.setProgressPercent(0);
        task.setLogTraceId("CALC-" + System.currentTimeMillis());
        task.setStartTime(new Date());
        task.setCreateBy(SecurityUtils.getUsername());
        task.setCreateTime(new Date());
        baseMapper.insert(task);

        Map<String, Object> stageContext = new LinkedHashMap<>();
        try {
            executeScheduleStage(task, scheduleStage, scheduleConfig, runtimePolicy, stageContext);
            updateTaskProgress(task, "WEIGHT_CALC", 25);

            if (shouldSkipWeightRecalculationStage(weightStage, weightConfig)) {
                executeWeightStageSkipped(task, indicatorSystem, weightStage, weightConfig, stageContext);
            } else {
                executeWeightStage(task, indicatorSystem, weightStage, weightConfig, stageContext);
            }
            updateTaskProgress(task, "COMPREHENSIVE_CALC", 55);

            executeComprehensiveStage(task, template, indicatorSystem, comprehensiveStage, comprehensiveConfig,
                    scheduleConfig, runtimePolicy, reportConfig, stageContext);
            updateTaskProgress(task, "REPORT_OUTPUT", 85);

            executeReportStage(task, template, indicatorSystem, reportStage, reportConfig, stageContext, scheduleConfig);

            task.setRunStatus("SUCCESS");
            task.setCurrentStage("FINISHED");
            task.setProgressPercent(100);
            task.setResultSummaryJson(JSON.toJSONString(stageContext.get("finalResult")));
            task.setEndTime(new Date());
            task.setUpdateBy(SecurityUtils.getUsername());
            task.setUpdateTime(new Date());
            baseMapper.updateById(task);
        } catch (Exception ex) {
            task.setRunStatus("FAILED");
            task.setProgressPercent(Math.max(task.getProgressPercent() == null ? 0 : task.getProgressPercent(), 1));
            task.setEndTime(new Date());
            task.setUpdateBy(SecurityUtils.getUsername());
            task.setUpdateTime(new Date());
            JSONObject errorSummary = new JSONObject();
            errorSummary.put("message", ex.getMessage());
            errorSummary.put("currentStage", task.getCurrentStage());
            task.setResultSummaryJson(errorSummary.toJSONString());
            baseMapper.updateById(task);
            throw ex instanceof ServiceException ? (ServiceException) ex : new ServiceException(ex.getMessage()).setDetailMessage(ex.getClass().getName());
        }

        return selectTaskDetail(task.getId());
    }

    private void executeScheduleStage(CalcTask task,
                                      JSONObject stage,
                                      JSONObject scheduleConfig,
                                      JSONObject runtimePolicy,
                                      Map<String, Object> stageContext) {
        CalcTaskStageLog log = buildStageLog(task, stage, "RUNNING");
        stageLogMapper.insert(log);
        try {
            JSONObject output = new JSONObject();
            output.put("routeStrategy", scheduleConfig.getString("routeStrategy"));
            output.put("executorName", scheduleConfig.getString("executorName"));
            output.put("timeoutSeconds", scheduleConfig.getInteger("timeoutSeconds"));
            output.put("retryTimes", scheduleConfig.getInteger("retryTimes"));
            output.put("blockStrategy", runtimePolicy == null ? "SERIAL_EXECUTION" : runtimePolicy.getString("blockStrategy"));
            output.put("misfireStrategy", runtimePolicy == null ? "DO_NOTHING" : runtimePolicy.getString("misfireStrategy"));
            JSONObject executionChain = new JSONObject();
            executionChain.put("xxlJobHandler", scheduleConfig.getString("executorName"));
            executionChain.put("algorithmHttp", "ZhpgCalcExecutor POST /zhpg-calc/execute");
            executionChain.put("equivalentXxlBean", "zhpgCalcHandler");
            executionChain.put("description",
                    "Weight stage can reuse indicator-system weights or recalculate inside ZHPG. "
                            + "Comprehensive stage calls ZhpgCalcExecutor. "
                            + "When XXL-JOB is configured, dispatch goes through XXL-JOB; otherwise it uses direct HTTP.");
            output.put("executionChain", executionChain);
            stageContext.put("executionChain", executionChain);
            stageContext.put("schedule", output);

            log.setExecuteStatus("SUCCESS");
            log.setOutputSummary(output.toJSONString());
            log.setFinishTime(new Date());
            stageLogMapper.updateById(log);
        } catch (Exception ex) {
            log.setExecuteStatus("FAILED");
            log.setErrorMessage(ex.getMessage());
            log.setFinishTime(new Date());
            stageLogMapper.updateById(log);
            throw ex;
        }
    }

    /**
     * Õ¿┤õ¢║Ôû╝Õª»Ôäâµ¥ÿÚèåÕ▒¥Úâ¿ÚÉóÒä¿þ╣ìþÉøÕ▒¥µñéÚÄ©Õø¿þêúµÁúµÆÂÚâ┤ÚÅëÕå«ÕÖ©ÚèåÕÂåµñéµÂôÕÂàõ╗øþü×ÕéÜþÂèµÂôÔé¼Úû▓ÕÂçþò╗ÚöøÕ▓Çµ┤┐ÚÄ║ÒâªÕª©ÚÄ©Õø¿þêúµÁúµÆÂÚâ┤ÚÅìµê£µ░ªþ╝üµ¼æµéúÚìÜÕáú¯à©þ╗áµÑàµ¿üÕ¿êþé╣Ôé¼?     */
    private boolean shouldSkipWeightRecalculationStage(JSONObject weightStage, JSONObject weightConfig) {
        if (weightStage != null && weightStage.containsKey("enabled")
                && Boolean.FALSE.equals(weightStage.getBoolean("enabled"))) {
            return true;
        }
        if (weightConfig == null) {
            return true;
        }
        String src = weightConfig.getString("weightSource");
        if (StringUtils.isBlank(src)) {
            return true;
        }
        return "INDICATOR_SYSTEM".equalsIgnoreCase(src.trim());
    }

    private void executeWeightStageSkipped(CalcTask task,
                                           EvalIndicatorSystem indicatorSystem,
                                           JSONObject stage,
                                           JSONObject weightConfig,
                                           Map<String, Object> stageContext) {
        task.setCurrentStage("WEIGHT_CALC");
        baseMapper.updateById(task);
        CalcTaskStageLog weightStageLog = buildStageLog(task, stage, "RUNNING");
        weightStageLog.setInputSummary(weightConfig == null ? "{}" : weightConfig.toJSONString());
        stageLogMapper.insert(weightStageLog);
        try {
            String rawTree = ZhpgIndicatorSystemTreeHelper.jsonForWeightCalculation(indicatorSystem);
            if (StringUtils.isBlank(rawTree)) {
                throw new ServiceException("ÚÄ©Õø¿þêúµÁúµÆÂÚâ┤ÚÄ©Õø¿þêúÚÅìµê£Þ┤ƒþ╗îþî┤þ┤ØÚÅâþè│þíÂÚÄÁÐå¯öæþÆü´╝äþò╗");
            }
            stageContext.put("weightedTreeJson", rawTree);
            stageContext.put("weightStageSkipped", Boolean.TRUE);

            JSONObject output = new JSONObject();
            output.put("skipped", true);
            output.put("reason", "use_indicator_system_weights");
            output.put("weightSource", weightConfig != null ? weightConfig.getString("weightSource") : null);
            weightStageLog.setExecuteStatus("SKIPPED");
            weightStageLog.setOutputSummary(output.toJSONString());
            weightStageLog.setFinishTime(new Date());
            stageLogMapper.updateById(weightStageLog);
            log.info("ÚÅëÕå«ÕÖ©ÚùâÞêÁ¯åîÕ«©ÞîÂþâªµØ®?taskId={}Úöøµ░¡Úâ¿ÚÉóÒäªÕ»ÜÚÅìÕøªþÂïþ╗»þ╗ÿþê▓ÚÅëÕå«ÕÖ©ÚöøÕØÁeightSource=INDICATOR_SYSTEMÚöøÕñøþ┤ØÚÉóÞ¥®µéúÚìÜÕáú¯à©þ╗áµÑàµ¿üÕ¿êõ¢âÕÜ£µÉ┤µø×µé£µÂôÕ®äþò╗ÚìÆÕùùÞïƒÚæ▒µ░¼µéÄ",
                    task.getId());
        } catch (Exception ex) {
            weightStageLog.setExecuteStatus("FAILED");
            weightStageLog.setErrorMessage(ex.getMessage());
            weightStageLog.setFinishTime(new Date());
            stageLogMapper.updateById(weightStageLog);
            throw ex;
        }
    }

    private void executeWeightStage(CalcTask task,
                                    EvalIndicatorSystem indicatorSystem,
                                    JSONObject stage,
                                    JSONObject weightConfig,
                                    Map<String, Object> stageContext) {
        task.setCurrentStage("WEIGHT_CALC");
        baseMapper.updateById(task);
        CalcTaskStageLog weightStageLog = buildStageLog(task, stage, "RUNNING");
        weightStageLog.setInputSummary(weightConfig.toJSONString());
        stageLogMapper.insert(weightStageLog);
        try {
            String strategy = "EQUAL_DISTRIBUTE".equals(weightConfig.getString("missingWeightPolicy")) ? "EQUAL" : "AUTO";
            WeightApplyResult result = indicatorTreeWeightService.applyWeights(
                    ZhpgIndicatorSystemTreeHelper.jsonForWeightCalculation(indicatorSystem),
                    strategy,
                    indicatorSystem.getWeightAssignAlgorithm()
            );
            stageContext.put("weightedTreeJson", result.getIndicatorTree());

            JSONObject output = new JSONObject();
            output.put("strategy", strategy);
            output.put("hint", result.getHint());
            output.put("treeUpdated", StringUtils.isNotBlank(result.getIndicatorTree()));
            weightStageLog.setExecuteStatus("SUCCESS");
            weightStageLog.setOutputSummary(output.toJSONString());
            weightStageLog.setFinishTime(new Date());
            stageLogMapper.updateById(weightStageLog);
            log.info("Weight stage completed inside ZHPG using IndicatorTreeWeightService, taskId={}",
                    task.getId());
        } catch (Exception ex) {
            weightStageLog.setExecuteStatus("FAILED");
            weightStageLog.setErrorMessage(ex.getMessage());
            weightStageLog.setFinishTime(new Date());
            stageLogMapper.updateById(weightStageLog);
            throw ex;
        }
    }

    private void executeComprehensiveStage(CalcTask task,
                                           CalcFlowTemplate template,
                                           EvalIndicatorSystem indicatorSystem,
                                           JSONObject stage,
                                           JSONObject comprehensiveConfig,
                                           JSONObject scheduleConfig,
                                           JSONObject runtimePolicy,
                                           JSONObject reportConfig,
                                           Map<String, Object> stageContext) {
        task.setCurrentStage("COMPREHENSIVE_CALC");
        baseMapper.updateById(task);
        CalcTaskStageLog stageLog = buildStageLog(task, stage, "RUNNING");
        stageLog.setInputSummary(comprehensiveConfig.toJSONString());
        stageLogMapper.insert(stageLog);
        try {
            // ÚÅïÕï½þ╝ôþÆïÕå¬µòñÚÄÁÐå¯öæÚìúÒäªµ╣çÚìö´╝äµ«æþÆçÚöïþ£░
            JSONObject executorRequest = new JSONObject();
            executorRequest.put("taskId", task.getId());
            executorRequest.put("taskName", task.getTaskName());
            executorRequest.put("templateId", template.getId());
            executorRequest.put("templateName", template.getTemplateName());
            executorRequest.put("indicatorSystemId", indicatorSystem.getId());
            executorRequest.put("indicatorSystemName", indicatorSystem.getSystemName());
            executorRequest.put("weightedTreeJson", stageContext.get("weightedTreeJson"));
            executorRequest.put("comprehensiveConfig", comprehensiveConfig);
            executorRequest.put("scheduleConfig", scheduleConfig);
            executorRequest.put("runtimePolicy", runtimePolicy);

            // ÚÄÂÒâÑµåíµØêµÆ│ÕÜ¡Úû░ÕÂçþûå
            executorRequest.put("reportConfig", reportConfig);

            // attach report template when configured
            Long reportTemplateId = reportConfig == null ? null : reportConfig.getLong("reportTemplateId");
            if (reportTemplateId != null && reportTemplateId > 0) {
                try {
                    ReportTemplate reportTemplate = reportTemplateService.getById(reportTemplateId);
                    if (reportTemplate != null && reportTemplate.getDeleted() != 1) {
                        JSONObject templateData = new JSONObject();
                        templateData.put("templateId", reportTemplate.getId());
                        templateData.put("templateName", reportTemplate.getTemplateName());
                        templateData.put("htmlContent", reportTemplate.getHtmlContent());
                        executorRequest.put("reportTemplate", templateData);
                        log.info("µÁáÞ»▓Õºƒ {} ÚìÅÕ«áõ╗êÚÄÂÒâÑµåíÕª»Ôäâµ¥ÿ: templateId={}, templateName={}",
                                task.getId(), reportTemplate.getId(), reportTemplate.getTemplateName());
                    } else {
                        log.warn("ÚÄÂÒâÑµåíÕª»Ôäâµ¥ÿµÂôÕÂàþô¿ÚìªÒäªÕ×¿Õ«©µÅÆÕ×╣Úùä? templateId={}", reportTemplateId);
                    }
                } catch (Exception e) {
                    log.error("Úæ¥Õ│░Õ¢çÚÄÂÒâÑµåíÕª»Ôäâµ¥ÿµ¥ÂÞ¥½Þºª: templateId={}", reportTemplateId, e);
                }
            }

            // dispatch the comprehensive calculation
            JSONObject result = callCalcExecutorService(executorRequest, template);
            stageContext.put("comprehensiveDispatchChannel", useXxlJobDispatch(template) ? "XXL_JOB" : "HTTP_DIRECT");
            stageContext.put("comprehensive", result);
            stageContext.put("finalResult", result);
            String scoredTree = result.getString("scoredIndicatorTreeJson");
            if (StringUtils.isNotBlank(scoredTree)) {
                stageContext.put("weightedTreeJson", scoredTree);
            }

            stageLog.setExecuteStatus("SUCCESS");
            stageLog.setOutputSummary(result.toJSONString());
            stageLog.setFinishTime(new Date());
            stageLogMapper.updateById(stageLog);
        } catch (Exception ex) {
            stageLog.setExecuteStatus("FAILED");
            stageLog.setErrorMessage(ex.getMessage());
            stageLog.setFinishTime(new Date());
            stageLogMapper.updateById(stageLog);
            throw ex;
        }
    }

    private JSONObject callCalcExecutorService(JSONObject request, CalcFlowTemplate template) {
        JSONObject scheduleCfg = request == null ? null : request.getJSONObject("scheduleConfig");
        String routeStrategy = scheduleCfg == null ? "FIRST" : scheduleCfg.getString("routeStrategy");
        int timeoutSeconds = scheduleCfg == null ? 300 : scheduleCfg.getIntValue("timeoutSeconds", 300);
        int retryTimes = scheduleCfg == null ? 0 : scheduleCfg.getIntValue("retryTimes", 0);
        int timeoutMs = timeoutSeconds <= 0 ? 300000 : timeoutSeconds * 1000;
        int maxAttempts = Math.max(0, retryTimes) + 1;
        Exception lastEx = null;

        // þÇÁþæ░ÕçíÚìÖµêØþ½ÀµÁúÕùùþÜ╗ÚÅê¯üàµò×ÚìÉ?xxl-job ÚÉ¿Õï¼─üÚÅëÕîíþ┤Ølazy Õ¿ëÒäÑÕö¢
        if (template.getXxlJobId() == null || template.getXxlJobId() <= 0) {
            try {
                calcFlowTemplateService.ensureXxlJobRegistered(template);
            } catch (Exception e) {
                log.warn("lazy xxl-job Õ¿ëÒäÑÕö¢µ¥ÂÞ¥½ÞºªÚöøÕ▒¢µ┤ûÚû½Ôé¼ HTTP ÚÉ®þúïþ╣ø: {}", e.getMessage());
            }
        }

        boolean viaXxl = useXxlJobDispatch(template);
        if (viaXxl) {
            log.info("ZHPG þ╝üþàÄµéÄþÆü´╝äþò╗þ╝ü?XXL-JOB þæÖ´╣ÇÕ¢é: adminBase={}, jobId={}, taskId={}",
                    xxlJobAdminBaseUrl, template.getXxlJobId(), request == null ? null : request.get("taskId"));
        } else {
            log.info("ZHPG comprehensive calculation uses direct HTTP. Configure "
                    + "zhpg.calc.xxl-job.admin-base-url to dispatch through XXL-JOB.");
        }

        for (int attempt = 1; attempt <= maxAttempts; attempt++) {
            try {
                if (viaXxl) {
                    return callCalcExecutorViaXxlJob(request, template, timeoutMs);
                }
                return callCalcExecutorByRoute(request, routeStrategy, timeoutMs);
            } catch (Exception ex) {
                lastEx = ex;
                if (attempt < maxAttempts) {
                    continue;
                }
            }
        }

        if (lastEx instanceof ServiceException) {
            throw (ServiceException) lastEx;
        }
        throw new ServiceException("call calc executor service failed after retries: "
                + (lastEx == null ? "unknown error" : lastEx.getMessage()));
    }

    private boolean useXxlJobDispatch(CalcFlowTemplate template) {
        return template.getXxlJobId() != null && template.getXxlJobId() > 0
                && StringUtils.isNotBlank(StringUtils.trimToNull(xxlJobAdminBaseUrl));
    }

    /**
     * þ╝ü?XXL-JOB Admin þæÖ´╣ÇÕ¢éþ╝üþàÄµéÄþÆü´╝äþò╗ÚöøÕ▓Çµò▒ÚÄÁÐå¯öæÚìúÒäÑÕòôÚìÑ?comprehensive_async_* ÚìÜÕ║íµ╣¬ÕºØÒéêþûåþÆç¯Ø¼Ôé¼?     */
    private JSONObject callCalcExecutorViaXxlJob(JSONObject request, CalcFlowTemplate template, int timeoutMs) {
        Long taskId = request.getLong("taskId");
        if (taskId == null) {
            throw new ServiceException("taskId is required for XXL-JOB dispatch");
        }
        resetComprehensiveAsyncState(taskId);
        try {
            xxlJobAdminClient.triggerJob(template.getXxlJobId(), request.toJSONString(), "");
            log.info("Õ«©µÅÆµé£ XXL-JOB Admin ÚÄ╗µä¬µ░ª trigger: jobId={}, taskId={}", template.getXxlJobId(), taskId);
            JSONObject result = pollComprehensiveAsyncResult(taskId, timeoutMs);
            clearComprehensiveAsyncState(taskId);
            return result;
        } catch (RuntimeException ex) {
            clearComprehensiveAsyncState(taskId);
            throw ex;
        }
    }

    private void resetComprehensiveAsyncState(Long taskId) {
        UpdateWrapper<CalcTask> uw = new UpdateWrapper<>();
        uw.eq("id", taskId).set("comprehensive_async_state", "PENDING");
        uw.setSql("comprehensive_async_json = NULL");
        baseMapper.update(null, uw);
    }

    private void clearComprehensiveAsyncState(Long taskId) {
        UpdateWrapper<CalcTask> uw = new UpdateWrapper<>();
        uw.eq("id", taskId);
        uw.setSql("comprehensive_async_state = NULL, comprehensive_async_json = NULL");
        baseMapper.update(null, uw);
    }

    private JSONObject pollComprehensiveAsyncResult(Long taskId, int timeoutMs) {
        long deadline = System.currentTimeMillis() + Math.max(timeoutMs, 5000);
        long sleepMs = 300;
        while (System.currentTimeMillis() < deadline) {
            CalcTask row = baseMapper.selectById(taskId);
            if (row == null) {
                throw new ServiceException("calc task not found when polling xxl result: " + taskId);
            }
            String st = row.getComprehensiveAsyncState();
            if ("SUCCESS".equals(st)) {
                String json = row.getComprehensiveAsyncJson();
                if (StringUtils.isBlank(json)) {
                    return new JSONObject();
                }
                return JSON.parseObject(json);
            }
            if ("FAIL".equals(st)) {
                String msg = StringUtils.defaultString(row.getComprehensiveAsyncJson(), "xxl comprehensive calc failed");
                throw new ServiceException(msg);
            }
            try {
                TimeUnit.MILLISECONDS.sleep(sleepMs);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
                throw new ServiceException("interrupted while waiting for xxl comprehensive calc");
            }
        }
        throw new ServiceException("þ╝üþàÄµéÄþÆü´╝äþò╗(XXL-JOB)þ╗øÕñèþÀƒþ╝üµÆ┤þüëþôÆÕæ«µñéÚöøÕ▓â¯ç¼ÚÅîÒâºµ╣àþÆïÕå¿Õ«│µÂô¯à×þ©¥ÚÄÁÐå¯öæÚÅâÒâÑþ╣öµÂôÕ║óÕó¢þÉøÕ▒¢µ½ÆÚÅä¯êÜµâüÕ«©µƒÑÕÄñþ╝â¯å╗þ¼ƒÚìöÔÇ│þ░▒ÚìÑþé▓Õòô");
    }

    private JSONObject callCalcExecutorByRoute(JSONObject request, String routeStrategy, int timeoutMs) {
        List<String> urls = parseExecutorUrls();
        if (urls.isEmpty()) {
            throw new ServiceException("calc executor url is not configured");
        }
        String strategy = StringUtils.defaultIfBlank(routeStrategy, "FIRST").toUpperCase();
        if ("SHARDING_BROADCAST".equals(strategy)) {
            return callBroadcastAndMerge(urls, request, timeoutMs);
        }
        List<String> ordered = buildOrderedUrls(strategy, urls, request);
        boolean allowFailover = "FAILOVER".equals(strategy) || "BUSYOVER".equals(strategy);
        int tryCount = allowFailover ? ordered.size() : 1;
        Exception lastEx = null;
        for (int i = 0; i < tryCount; i++) {
            String base = ordered.get(i);
            try {
                JSONObject result = doCallExecutor(base, request, timeoutMs);
                markExecutorUsed(base);
                return result;
            } catch (Exception ex) {
                lastEx = ex;
            }
        }
        if (lastEx instanceof ServiceException) {
            throw (ServiceException) lastEx;
        }
        throw new ServiceException("all routed executor calls failed");
    }

    private JSONObject doCallExecutor(String baseUrl, JSONObject request, int timeoutMs) {
        try {
            RestTemplate restTemplate = buildRestTemplate(timeoutMs);
            String url = StringUtils.removeEnd(baseUrl, "/") + "/zhpg-calc/execute";
            org.springframework.http.HttpEntity<JSONObject> httpEntity = new org.springframework.http.HttpEntity<>(request);
            org.springframework.http.ResponseEntity<JSONObject> response = restTemplate.postForEntity(url, httpEntity, JSONObject.class);
            if (response.getStatusCode() == org.springframework.http.HttpStatus.OK) {
                JSONObject body = response.getBody();
                if (body == null) {
                    throw new ServiceException("calc executor service returned empty body");
                }
                return unwrapAjaxResult(body);
            }
            throw new ServiceException("calc executor service returned: " + response.getStatusCode());
        } catch (RestClientException ex) {
            throw new ServiceException("call calc executor service failed: " + ex.getMessage());
        }
    }

    private JSONObject unwrapAjaxResult(JSONObject body) {
        if (body == null) {
            throw new ServiceException("calc executor returned empty body");
        }
        int code = parseAjaxCode(body.get("code"));
        if (code != HttpStatus.SUCCESS) {
            String msg = body.getString("msg");
            throw new ServiceException(StringUtils.isNotBlank(msg) ? msg : "calc executor returned error, code=" + code);
        }
        if (!body.containsKey("data")) {
            return body;
        }
        Object data = body.get("data");
        if (data instanceof JSONObject) {
            return (JSONObject) data;
        }
        if (data != null) {
            return JSONObject.parseObject(JSON.toJSONString(data));
        }
        throw new ServiceException("calc executor ajax result has no data");
    }

    private JSONObject buildCallbackPayload(String resultJson, String reportUrl, String wordUrl, String wpsUrl) {
        JSONObject payload = new JSONObject();
        Object result = parseJsonText(resultJson);
        payload.put("result", result != null ? result : resultJson);
        if (StringUtils.isNotBlank(reportUrl)) {
            payload.put("reportUrl", reportUrl);
        }
        if (StringUtils.isNotBlank(wordUrl)) {
            payload.put("wordUrl", wordUrl);
        }
        if (StringUtils.isNotBlank(wpsUrl)) {
            payload.put("wpsUrl", wpsUrl);
        }
        return payload;
    }

    private String resolveAsyncTaskStatus(CalcTask task) {
        if (task == null || StringUtils.isBlank(task.getRunStatus())) {
            return "PENDING";
        }
        if ("RUNNING".equalsIgnoreCase(task.getRunStatus())
                && "PENDING".equalsIgnoreCase(task.getComprehensiveAsyncState())) {
            return "DISPATCHED";
        }
        return task.getRunStatus();
    }

    private String extractErrorMessage(String jsonText) {
        Object payload = parseJsonText(jsonText);
        if (payload instanceof JSONObject) {
            JSONObject json = (JSONObject) payload;
            String msg = json.getString("message");
            if (StringUtils.isBlank(msg)) {
                msg = json.getString("msg");
            }
            if (StringUtils.isNotBlank(msg)) {
                return msg;
            }
        }
        return payload == null ? null : String.valueOf(payload);
    }

    private Object parseJsonText(String jsonText) {
        if (StringUtils.isBlank(jsonText)) {
            return null;
        }
        try {
            return JSON.parse(jsonText);
        } catch (Exception ex) {
            return jsonText;
        }
    }

    private static int parseAjaxCode(Object codeObj) {
        if (codeObj == null) {
            return HttpStatus.SUCCESS;
        }
        if (codeObj instanceof Number) {
            return ((Number) codeObj).intValue();
        }
        if (codeObj instanceof String) {
            try {
                return Integer.parseInt((String) codeObj);
            } catch (NumberFormatException e) {
                return HttpStatus.SUCCESS;
            }
        }
        return HttpStatus.SUCCESS;
    }

    /**
     * ÚùâÞêÁ¯åîµÂôÕ®üþ¼àÚÅéÕøªÞàæÚìÖ¯êØÕàÿþÇø?JSONObjectÚèåõ©úSON þÇøµÑâ¯âüµÂôÕÅëÕ×¿ MapÚöøÕáØÕ╝¢µÉ┤Õ┐ôÕ×¬ÚìûµáÁþ┤ÜÚöøÕ▓Çþ▓║µÂôÔé¼µØ×¯â┐Þ┤ƒ JSONObjectÚèå?     */
    private JSONObject parseStageContextJsonObject(Object raw) {
        if (raw == null) {
            return null;
        }
        if (raw instanceof JSONObject) {
            return (JSONObject) raw;
        }
        if (raw instanceof String) {
            String s = ((String) raw).trim();
            if (s.isEmpty()) {
                return null;
            }
            try {
                return JSON.parseObject(s);
            } catch (Exception e) {
                return null;
            }
        }
        try {
            return JSON.parseObject(JSON.toJSONString(raw));
        } catch (Exception e) {
            return null;
        }
    }

    private RestTemplate buildRestTemplate(int timeoutMs) {
        SimpleClientHttpRequestFactory factory = new SimpleClientHttpRequestFactory();
        factory.setConnectTimeout(timeoutMs);
        factory.setReadTimeout(timeoutMs);
        return new RestTemplate(factory);
    }

    private List<String> parseExecutorUrls() {
        List<String> urls = new ArrayList<>();
        String[] parts = StringUtils.split(calcExecutorUrl, ",");
        if (parts == null) {
            return urls;
        }
        for (String part : parts) {
            if (StringUtils.isNotBlank(part)) {
                urls.add(part.trim());
            }
        }
        return urls;
    }

    private List<String> buildOrderedUrls(String strategy, List<String> urls, JSONObject request) {
        List<String> ordered = new ArrayList<>(urls);
        switch (strategy) {
            case "LAST":
                Collections.reverse(ordered);
                return ordered;
            case "ROUND": {
                int start = (int) (Math.abs(ROUTE_ROUND_COUNTER.getAndIncrement()) % ordered.size());
                return rotateFrom(ordered, start);
            }
            case "RANDOM":
                Collections.shuffle(ordered, ThreadLocalRandom.current());
                return ordered;
            case "CONSISTENT_HASH": {
                int hashKey = request == null ? 0 : request.getIntValue("taskId", 0);
                int start = Math.abs(hashKey) % ordered.size();
                return rotateFrom(ordered, start);
            }
            case "LEAST_FREQUENTLY_USED": {
                String first = ordered.stream()
                        .min((a, b) -> Long.compare(getUseCount(a), getUseCount(b)))
                        .orElse(ordered.get(0));
                return moveFirst(ordered, first);
            }
            case "LEAST_RECENTLY_USED":
            case "BUSYOVER": {
                String first = ordered.stream()
                        .min((a, b) -> Long.compare(getLastUsed(a), getLastUsed(b)))
                        .orElse(ordered.get(0));
                return moveFirst(ordered, first);
            }
            case "FAILOVER":
            case "FIRST":
            default:
                return ordered;
        }
    }

    private List<String> rotateFrom(List<String> urls, int start) {
        List<String> ordered = new ArrayList<>(urls.size());
        for (int i = 0; i < urls.size(); i++) {
            ordered.add(urls.get((start + i) % urls.size()));
        }
        return ordered;
    }

    private List<String> moveFirst(List<String> urls, String first) {
        List<String> ordered = new ArrayList<>(urls);
        ordered.remove(first);
        ordered.add(0, first);
        return ordered;
    }

    private long getUseCount(String url) {
        AtomicLong counter = executorUseCounter.get(url);
        return counter == null ? 0L : counter.get();
    }

    private long getLastUsed(String url) {
        Long value = executorLastUseTime.get(url);
        return value == null ? 0L : value;
    }

    private void markExecutorUsed(String url) {
        executorUseCounter.computeIfAbsent(url, key -> new AtomicLong(0L)).incrementAndGet();
        executorLastUseTime.put(url, System.currentTimeMillis());
    }

    private JSONObject callBroadcastAndMerge(List<String> urls, JSONObject request, int timeoutMs) {
        List<JSONObject> successResults = new ArrayList<>();
        for (String base : urls) {
            try {
                JSONObject one = doCallExecutor(base, request, timeoutMs);
                markExecutorUsed(base);
                successResults.add(one);
            } catch (Exception ignore) {
                // Ú¬×µîÄµî▒Õª»ÔÇ│þ┤íÚìÅõ¢¢¯åÅÚû«ÒäÑÕ×ÄÚæ║Õé£Õüúµ¥ÂÞ¥½ÞºªÚöøÕ▒¢Õ¢ºþæòõ¢╣µ╣üÚÄ┤µä¼Õºøþ╝üµÆ┤þüëÚìùÕå▓Õ¢▓
            }
        }
        if (successResults.isEmpty()) {
            throw new ServiceException("sharding broadcast failed: no executor returned success");
        }
        if (successResults.size() == 1) {
            return successResults.get(0);
        }
        JSONObject merged = new JSONObject(successResults.get(0));
        BigDecimal total = BigDecimal.ZERO;
        for (JSONObject one : successResults) {
            BigDecimal score = one.getBigDecimal("score");
            total = total.add(score == null ? BigDecimal.ZERO : score);
        }
        BigDecimal avg = total.divide(BigDecimal.valueOf(successResults.size()), 2, BigDecimal.ROUND_HALF_UP);
        merged.put("score", avg);
        merged.put("conclusion", "ÚìÆÕùÖÕóûÚ¬×µîÄµî▒Úæ▒µ░¼µéÄþÇ╣Õ▒¥Õ×ÜÚöøÕ▒¢ÕÅí " + successResults.size() + " µÂô¯üàÕó¢þÉøÕ▒¢µ½ÆÚìÖÕéÖþ¼î");
        return merged;
    }

    private void applyBlockAndMisfirePolicy(Long templateId, JSONObject runtimePolicy) {
        String blockStrategy = runtimePolicy == null ? "SERIAL_EXECUTION"
                : StringUtils.defaultIfBlank(runtimePolicy.getString("blockStrategy"), "SERIAL_EXECUTION");
        String misfireStrategy = runtimePolicy == null ? "DO_NOTHING"
                : StringUtils.defaultIfBlank(runtimePolicy.getString("misfireStrategy"), "DO_NOTHING");

        QueryWrapper<CalcTask> runningQuery = new QueryWrapper<>();
        runningQuery.eq("calc_flow_template_id", templateId).eq("run_status", "RUNNING");
        List<CalcTask> runningTasks = baseMapper.selectList(runningQuery);
        if (runningTasks == null || runningTasks.isEmpty()) {
            return;
        }

        if ("COVER_EARLY".equalsIgnoreCase(blockStrategy)) {
            terminateRunningTasks(runningTasks, "covered by new trigger");
            return;
        }

        if ("FIRE_ONCE_NOW".equalsIgnoreCase(misfireStrategy)) {
            return;
        }

        if ("DISCARD_LATER".equalsIgnoreCase(blockStrategy)) {
            throw new ServiceException("executor blocked, discard current trigger by DISCARD_LATER");
        }
        throw new ServiceException("executor blocked, serial execution is in progress");
    }

    private void terminateRunningTasks(List<CalcTask> runningTasks, String reason) {
        Date now = new Date();
        for (CalcTask one : runningTasks) {
            one.setRunStatus("TERMINATED");
            one.setEndTime(now);
            one.setUpdateBy(SecurityUtils.getUsername());
            one.setUpdateTime(now);
            baseMapper.updateById(one);
        }
    }

    private void executeReportStage(CalcTask task,
                                    CalcFlowTemplate template,
                                    EvalIndicatorSystem indicatorSystem,
                                    JSONObject stage,
                                    JSONObject reportConfig,
                                    Map<String, Object> stageContext,
                                    JSONObject scheduleConfig) {
        task.setCurrentStage("REPORT_OUTPUT");
        baseMapper.updateById(task);
        CalcTaskStageLog stageLog = buildStageLog(task, stage, "RUNNING");
        stageLog.setInputSummary(reportConfig.toJSONString());
        stageLogMapper.insert(stageLog);
        try {
            JSONObject finalResult = parseStageContextJsonObject(stageContext.get("finalResult"));
            if (finalResult == null) {
                finalResult = new JSONObject();
            }
            JSONObject weightedTree = parseStageContextJsonObject(stageContext.get("weightedTreeJson"));
            JSONArray outputTargets = reportConfig.getJSONArray("outputTargets");
            JSONObject output = new JSONObject();
            output.put("outputTargets", outputTargets);
            output.put("reportTemplateId", reportConfig.getLong("reportTemplateId"));
            output.put("autoArchive", reportConfig.getBoolean("autoArchive"));

            // ÚÅïÕï½þ╝ôÚÄÂÒâÑµåíÚÅüþëêÕÁüµÂôÕ®üþ¼àÚÅéÕøÀþ┤ÖÚÅÇ¯êøÕ»öÚìùþè▒þÂàþ╗ù´©¢µººþüÅÕïÂþ┤Ü
            JSONObject reportDataContext = buildReportDataContext(reportConfig, finalResult, weightedTree, task);
            output.put("reportDataContext", reportDataContext);
            if (scheduleConfig != null) {
                output.put("scheduleExecutorName", scheduleConfig.getString("executorName"));
            }

            if (containsTarget(outputTargets, "RESULT_DB")) {
                EvalResult evalResult = buildEvalResult(task, template, indicatorSystem, finalResult,
                        reportDataContext, stageContext, reportConfig);
                if (StringUtils.isBlank(evalResult.getResultCode())) {
                    evalResult.setResultCode("RES-" + System.currentTimeMillis());
                }
                try {
                    tryUploadEvalReportToMinio(evalResult, task, reportConfig, reportDataContext);
                } catch (Exception reportEx) {
                    log.warn("ÚÄÂÒâÑµåíÕ¿ôÕÅëþàï/µÂôÕ®üþ┤Âµ¥ÂÞ¥½ÞºªÚöøÕ▓âþÿÄµÁ╝µë«þ▓¿ÚÅïµ╗Çþ▓øµÁ╝µ░│µâñµÉ┤µÆ▓þÁ¥ reportUrl µÂôÞÖ╣Ôöû: calcTaskId={}, resultCode={}",
                            task.getId(), evalResult.getResultCode(), reportEx);
                    mergeReportPayloadNote(evalResult, "reportGenerationError",
                            reportEx.getMessage() == null ? reportEx.toString() : reportEx.getMessage());
                }
                evalResultService.insertEvalResult(evalResult);
                output.put("evalResultId", evalResult.getId());
                output.put("resultCode", evalResult.getResultCode());
                output.put("reportUrl", evalResult.getReportUrl());
                if (StringUtils.isNotBlank(evalResult.getReportPayloadJson())) {
                    try {
                        JSONObject po = JSON.parseObject(evalResult.getReportPayloadJson());
                        output.put("reportGenerationError", po.getString("reportGenerationError"));
                    } catch (Exception ignore) {
                        // ignore
                    }
                }
            }

            stageLog.setExecuteStatus("SUCCESS");
            stageLog.setOutputSummary(output.toJSONString());
            stageLog.setFinishTime(new Date());
            stageLogMapper.updateById(stageLog);
        } catch (Exception ex) {
            stageLog.setExecuteStatus("FAILED");
            stageLog.setErrorMessage(ex.getMessage());
            stageLog.setFinishTime(new Date());
            stageLogMapper.updateById(stageLog);
            throw ex;
        }
    }

    /**
     * ÚÅïÕï½þ╝ôÚÄÂÒâÑµåíÚÅüþëêÕÁüµÂôÕ®üþ¼àÚÅéÕøÀþ┤ØÚÅÇ¯êøÕ»öÚû½µ░▒µòñÚìùþè▒þÂàþ╗ù´╣üÕÜ£ÚìöÒäªµººþüÅ?     */
    private JSONObject buildReportDataContext(JSONObject reportConfig, JSONObject finalResult,
                                               JSONObject weightedTree, CalcTask task) {
        JSONObject context = new JSONObject();
        if (finalResult == null) {
            finalResult = new JSONObject();
        }

        // 1. Úì®ÞÖ╣¯öàþÆü´╝äþò╗þ╝üµÆ┤þüëþÇøµÑü¯åî
        context.put("score", finalResult.getBigDecimal("score"));
        context.put("grade", finalResult.getString("grade"));
        context.put("conclusion", finalResult.getString("conclusion"));
        context.put("suggestion", finalResult.getString("suggestion"));

        // 2. þ╝üµØæÕ«│ÚÅüþëêÕÁü
        JSONArray dimensions = finalResult.getJSONArray("dimensions");
        if (dimensions != null) {
            context.put("indicator_dimensions", dimensions);
        }

        // 3. µÁáÕ║íÕº×ÚÅëÕå®þê▓ÚÅïÕï½þ╝ôÚÄ©Õø¿þêúÚÅüþëêÕÁüþ╝üµÆ┤þÇ»ÚöøÕáØÕÉïþÇ╣Õ¢ÆÒÇèþü×?treeData ÚìûÕæ░¯ùèÚöø?        if (weightedTree != null) {
            weightedTree = unwrapIndicatorTreeRootForReport(weightedTree);
            // þÇ╣Õ▒¥µÜúÚÄ©Õø¿þêúÚÅìµê»þ┤ÖÚìÜ¯éÑ¯à©þ╗áµÑÇÔé¼þíÀþ┤Ü
            context.put("indicator_tree", weightedTree);

            // ÚÄÁõ¢©ÚÆ®Úìûµá¿ÕóìÚÅêÕñÄÕª¡ÚÉÉ?            JSONArray allNodes = flattenIndicatorTree(weightedTree);
            context.put("indicator_nodes_flat", allNodes);

            // ÚìÆÕùÖ¯×çÚìÖÞÀ║þôÖÚæ║Õé£ÕüúÚì£Õ▒╝ÞàæÚùéþúïÕª¡ÚÉÉ?            JSONArray leafNodes = new JSONArray();
            JSONArray intermediateNodes = new JSONArray();
            for (int i = 0; i < allNodes.size(); i++) {
                JSONObject node = allNodes.getJSONObject(i);
                Boolean isLeaf = node.getBoolean("isLeaf");
                if (Boolean.TRUE.equals(isLeaf)) {
                    leafNodes.add(node);
                } else {
                    intermediateNodes.add(node);
                }
            }
            context.put("leaf_nodes_scores", leafNodes);
            context.put("intermediate_nodes_scores", intermediateNodes);

            // Úæ║Õé£Õüúþ╝üþå╗¯à©
            JSONObject nodeStats = new JSONObject();
            nodeStats.put("total", allNodes.size());
            nodeStats.put("leaf", leafNodes.size());
            nodeStats.put("intermediate", intermediateNodes.size());
            context.put("node_count_stats", nodeStats);

            // ÚÄ©Õø¿þêúþü×Õé£Ú¬çÚû¼ÕÂàÕÀ╗ÚÅìµê»þ┤ÖµÁáÕ║óþë┤Úæ║Õé£ÕüúchildrenÕ»«Ôé¼µ┐«Õ¼Âþ┤ØÚæÀ¯üäÕº®Úû½µÄæþÂèÚÄÁÔé¼ÚÅêÕñèþ£░þ╗¥Ðìþ┤Ü
            JSONArray indicatorHierarchy = buildIndicatorHierarchy(weightedTree);
            context.put("indicator_hierarchy", indicatorHierarchy);

            // þ╝üµØæÕ«│Úæ║Õé£ÕüúÚìÆµÑäÒÇâÚöøÕáƒþë┤Úæ║Õé£ÕüúµÂôÕ¼¼µ«æþ╗ù¯â┐þ½┤þü×Õéªþ┤ØÚìùÕààþ½┤þ╗¥ÐàµÀ«µÉ┤´©╝þ┤Ü
            JSONArray dimensionNodes = extractDimensionNodes(weightedTree);
            context.put("dimension_nodes", dimensionNodes);

            // ÚÄÁÔé¼ÚÅêÕñèÕ¢¥þÇøµä»Õª¡ÚÉÉþæ░Õ×¬þÉø?            context.put("all_leaf_nodes", leafNodes);

            // ÚÄ©Õø¿þêúÕº╣Õø¿Ôé¼µÿÅÒÇâÚÅüþëêÕÁüÚöøÕáØµâêþü×Õé£Ú¬ç/þÆçÕï¬ÕÅèÚìè?ÚÅëÕå«ÕÖ©/ÚùâÕáØÔé¼þíÀþ┤Ü
            JSONArray summaryTable = buildIndicatorSummaryTable(allNodes);
            context.put("indicator_summary_table", summaryTable);

            // þ╝üµØæÕ«│Õ»░µÑÇÕ×ÄÕº╣Õø¿Ôé¼?            context.put("dimension_summary", buildDimensionSummary(weightedTree, finalResult));

            // ÚìÖÞÀ║þôÖÚæ║Õé£ÕüúþÆç´©¥þ▓ÅþÆçÕï¬ÕÅèÚÅüþëêÕÁü
            context.put("leaf_evaluation_details", buildLeafEvaluationDetails(leafNodes));
        }

        // 4. task metadata
        context.put("taskName", task.getTaskName());
        context.put("startTime", task.getStartTime());
        context.put("endTime", task.getEndTime());

        // 5. placeholder mappings
        JSONArray placeholderMappings = reportConfig.getJSONArray("placeholderMappings");
        if (placeholderMappings != null) {
            JSONObject mappedData = applyPlaceholderMappings(placeholderMappings, context,
                    finalResult, weightedTree, task);
            context.putAll(mappedData);
        }

        return context;
    }

    private JSONObject unwrapIndicatorTreeRootForReport(JSONObject tree) {
        if (tree == null) {
            return null;
        }
        JSONObject inner = tree.getJSONObject("treeData");
        return inner != null ? inner : tree;
    }

    /**
     * þüÅÕùÿÕ»ÜÚÅìÕø¿þê▓ÚÄÁõ¢©ÚÆ®ÚìûµáªÞ┤ƒÚæ║Õé£ÕüúÚìÆµÑäÒÇâ
     */
    private JSONArray flattenIndicatorTree(JSONObject tree) {
        JSONArray result = new JSONArray();
        if (tree == null) return result;
        flattenNode(tree, result, null, 0);
        return result;
    }

    private void flattenNode(JSONObject node, JSONArray result, String parentId, int level) {
        if (node == null) return;

        JSONObject flatNode = new JSONObject();
        flatNode.put("id", node.getString("id"));
        flatNode.put("label", node.getString("label"));
        flatNode.put("code", node.getString("code"));
        flatNode.put("level", level);
        flatNode.put("parentId", parentId);
        flatNode.put("weight", node.getBigDecimal("weight"));
        flatNode.put("calculatedValue", node.getBigDecimal("calculatedValue"));
        flatNode.put("score", node.getBigDecimal("score"));

        JSONArray children = node.getJSONArray("children");
        boolean isLeaf = children == null || children.isEmpty();
        flatNode.put("isLeaf", isLeaf);

        result.add(flatNode);

        if (children != null) {
            String nodeId = node.getString("id");
            for (int i = 0; i < children.size(); i++) {
                flattenNode(children.getJSONObject(i), result, nodeId, level + 1);
            }
        }
    }

    /**
     * µÉ┤µùéµòñÚìùþè▒þÂàþ╗ù´©¢µººþüÅÕï»ÕÄñþ╝â?     */
    private JSONObject applyPlaceholderMappings(JSONArray mappings, JSONObject context,
                                                 JSONObject finalResult, JSONObject weightedTree,
                                                 CalcTask task) {
        JSONObject result = new JSONObject();
        if (mappings == null) return result;

        for (int i = 0; i < mappings.size(); i++) {
            JSONObject mapping = mappings.getJSONObject(i);
            String key = mapping.getString("key");
            String mappingType = mapping.getString("mappingType");
            String mappingValue = mapping.getString("mappingValue");

            if (key == null || mappingType == null) continue;

            switch (mappingType) {
                case "STATIC_TEXT":
                    result.put(key, mappingValue);
                    break;
                case "AUTO_INDICATOR":
                    // ÚæÀ¯üäÕº®ÚÄ©Õø¿þêúÚÅüþëêÕÁü - µÁáÕ║Øþ¼éµÂôÕ¼½µ×âÚæ¥Õ│░Õ¢ç
                    Object autoValue = getAutoIndicatorValue(mappingValue, context, finalResult);
                    result.put(key, autoValue);
                    break;
                case "INDICATOR_RESULT":
                    // ÚÄ©Õøºþò¥ÚÄ©Õø¿þêúÚæ║Õé£Õüú - µÁáÕ║íÕº×ÚÅëÕå®þê▓µÂô¯àƒþàíÚÄÁÕëºÕúÆþÇ╣µ░│Õª¡ÚÉÉ?                    Object specificValue = findSpecificNodeValue(mappingValue, weightedTree);
                    result.put(key, specificValue);
                    break;
                case "TASK_PROPERTY":
                    // µÁáÞ»▓Õºƒþü×þé┤Ôé¼?                    Object taskValue = getTaskPropertyValue(mappingValue, task);
                    result.put(key, taskValue);
                    break;
                default:
                    result.put(key, "");
            }
        }
        return result;
    }

    /**
     * Úæ¥Õ│░Õ¢çÚæÀ¯üäÕº®ÚÄ©Õø¿þêúÚÅüþëêÕÁüÚìè?     */
    private Object getAutoIndicatorValue(String mappingValue, JSONObject context, JSONObject finalResult) {
        if (mappingValue == null) return null;

        switch (mappingValue) {
            case "eval_result_snapshot": {
                JSONObject snap = new JSONObject();
                snap.put("score", finalResult.getBigDecimal("score"));
                snap.put("grade", finalResult.getString("grade"));
                snap.put("conclusion", finalResult.getString("conclusion"));
                snap.put("suggestion", finalResult.getString("suggestion"));
                return snap;
            }
            // Úì®ÞÖ╣¯öàÚÅüþëêÕÁüþ╝üµÆ┤þÇ»
            case "indicator_tree":
                return context.get("indicator_tree");
            case "indicator_nodes_flat":
                return context.get("indicator_nodes_flat");
            case "indicator_dimensions":
                return context.get("indicator_dimensions");

            // þü×Õé£Ú¬çÚû¼ÕÂàÕÀ╗ÚÅüþëêÕÁü
            case "indicator_hierarchy":
                return context.get("indicator_hierarchy");
            case "dimension_nodes":
                return context.get("dimension_nodes");
            case "all_leaf_nodes":
                return context.get("all_leaf_nodes");

            // Õº╣Õø¿Ôé¼µÿÅÒÇâÚÅìÕà╝µÜƒÚÄ╣?            case "indicator_summary_table":
                return context.get("indicator_summary_table");
            case "dimension_summary":
                return context.get("dimension_summary");
            case "leaf_evaluation_details":
                return context.get("leaf_evaluation_details");

            // þÆü´╝äþò╗þ╝üµÆ┤þüëÕº╣Õø¿Ôé¼?            case "overall_score":
                return finalResult.getBigDecimal("score");
            case "overall_grade":
                return finalResult.getString("grade");
            case "overall_conclusion":
                return finalResult.getString("conclusion");
            case "overall_suggestion":
                return finalResult.getString("suggestion");

            // Úæ║Õé£Õüúþ╝üþå╗¯à©
            case "leaf_nodes_scores":
                return context.get("leaf_nodes_scores");
            case "intermediate_nodes_scores":
                return context.get("intermediate_nodes_scores");
            case "node_count_stats":
                return context.get("node_count_stats");

            default:
                return context.get(mappingValue);
        }
    }

    /**
     * ÚÅîÒâªÕúÿÚÄ©Õøºþò¥ÚÄ©Õø¿þêúÚæ║Õé£ÕüúÚÉ¿Õï½Ôé¼?     */
    private Object findSpecificNodeValue(String nodeId, JSONObject tree) {
        if (tree == null || nodeId == null) return null;
        if (nodeId.equals(tree.getString("id"))) {
            return tree;
        }
        JSONArray children = tree.getJSONArray("children");
        if (children != null) {
            for (int i = 0; i < children.size(); i++) {
                Object found = findSpecificNodeValue(nodeId, children.getJSONObject(i));
                if (found != null) return found;
            }
        }
        return null;
    }

    /**
     * ÚÅïÕï½þ╝ôÚÄ©Õø¿þêúþü×Õé£Ú¬çÚû¼ÕÂàÕÀ╗ÚÅìµê»þ┤ÖµÁáÕ║óþë┤Úæ║Õé£ÕüúchildrenÕ»«Ôé¼µ┐«Õ¼Âþ┤ØÚæÀ¯üäÕº®Úû½µÄæþÂèÚÄÁÔé¼ÚÅêÕñèþ£░þ╗¥Ðìþ┤Ü
     * ÚÉóÒäñþ░¼Õª»Ôäâµ¥ÿµÂô¯àáµ«æþü×Õé£Ú¬çÚû¼ÕÂàÕÀ╗ÚöøÕ▒¥µò«ÚÄ©õ¢ÀµìóÚÄ░Õ┐öþ╣üµÉ┤´©¥µ«æÚÄ©Õø¿þêúµÁúµÆÂÚâ┤
     */
    private JSONArray buildIndicatorHierarchy(JSONObject tree) {
        JSONArray result = new JSONArray();
        if (tree == null) return result;

        // µÁáÕ║óþë┤Úæ║Õé£ÕüúÚÉ¿ÕêóhildrenÕ»«Ôé¼µ┐«Õ¼Âþ┤ÖþÆ║Õ«áþ╣âÚÅìþíàÕª¡ÚÉÉÞºäµ╣░Úƒ¼¯é¼þ┤ØÚìÑþè▒Þ┤ƒÚÅìþíàÕª¡ÚÉÉÕ¢ÆÔé¼µ░¼þêÂÚìÖ¯üàµ╣üµÂôÔé¼µÂô¯üâþ¼ûÚÅä¯êøþ£╣ÚÄ¼µÿÅÕª¡ÚÉÉþÖ©þ┤Ü
        JSONArray rootChildren = tree.getJSONArray("children");
        if (rootChildren == null) return result;

        for (int i = 0; i < rootChildren.size(); i++) {
            JSONObject node = rootChildren.getJSONObject(i);
            JSONObject processedNode = processHierarchyNode(node, 1, null);
            if (processedNode != null) {
                result.add(processedNode);
            }
        }

        return result;
    }

    /**
     * Úû½µÄæþÂèµ¥ÂÕï¡µéèþü×Õé£Ú¬çÚæ║Õé£Õüú
     */
    private JSONObject processHierarchyNode(JSONObject node, int level, String parentLabel) {
        if (node == null) return null;

        JSONObject result = extractNodeBasicInfo(node);
        result.put("level", level);
        result.put("parentLabel", parentLabel);

        JSONArray children = node.getJSONArray("children");
        boolean isLeaf = children == null || children.isEmpty();
        result.put("isLeaf", isLeaf);

        // Õ¿úÞ»▓Õº×þÆçÕï¬ÕÅèþ╝üµÆ╣¯åæ
        BigDecimal score = node.getBigDecimal("score");
        result.put("evaluationConclusion", evaluateScore(score));

        if (isLeaf) {
            // ÚìÖÞÀ║þôÖÚæ║Õé£ÕüúÚöøµ░¡ÕØèÚìöþè╗µºçÚìèÚù┤õ┐èÚÄ¡?            JSONObject thresholds = extractThresholds(node);
            if (thresholds != null) {
                result.put("thresholds", thresholds);
            }
        } else {
            // Úùêþé▓Õ¢¥þÇøµä»Õª¡ÚÉÉþÖ©þ┤░Úû½µÄæþÂèµ¥ÂÕï¡µéèþÇøµä»Õª¡ÚÉÉ?            JSONArray processedChildren = new JSONArray();
            String nodeLabel = node.getString("label");
            for (int i = 0; i < children.size(); i++) {
                JSONObject child = processHierarchyNode(children.getJSONObject(i), level + 1, nodeLabel);
                if (child != null) {
                    processedChildren.add(child);
                }
            }
            result.put("children", processedChildren);
            // Õ¿úÞ»▓Õº×þÇøµä»Õª¡ÚÉÉÞºäµÜƒÚû▓?            result.put("childCount", processedChildren.size());
        }

        return result;
    }

    /**
     * ÚÄ╗µä¼Õ¢çþ╝üµØæÕ«│Úæ║Õé£ÕüúÚìÆµÑäÒÇâÚöøÕáƒþë┤Úæ║Õé£ÕüúµÂôÕ¼¼µ«æþ╗ù¯â┐þ½┤þü×Õéªþ┤Ü
     */
    private JSONArray extractDimensionNodes(JSONObject tree) {
        JSONArray result = new JSONArray();
        if (tree == null) return result;

        // ÚÅìþíàÕª¡ÚÉÉÚÇøþ¼àÚÉ¿ÕêóhildrenþüÅÞ¥¿µº©þ╝üµØæÕ«│Úæ║Õé£Õüú
        JSONArray rootChildren = tree.getJSONArray("children");
        if (rootChildren == null) return result;

        for (int i = 0; i < rootChildren.size(); i++) {
            JSONObject dimNode = rootChildren.getJSONObject(i);
            JSONObject dimData = extractNodeBasicInfo(dimNode);
            dimData.put("level", 1);
            dimData.put("index", i + 1);  // ÚÉóÒäñþ░¼þ╝éµáºÕ¢┐µ┐í?4.1, 4.2
            dimData.put("evaluationConclusion", evaluateScore(dimNode.getBigDecimal("score")));

            // þ╝üþå╗¯à©þÆçÒâºµÀ«µÉ┤´©┐þ¼àÚÉ¿Õï½Õ¢¥þÇøµä»Õª¡ÚÉÉÞºäµÜƒÚû▓?            int leafCount = countLeafNodes(dimNode);
            dimData.put("indicatorCount", leafCount);

            result.add(dimData);
        }

        return result;
    }

    /**
     * ÚÄ╗µä¼Õ¢çÚæ║Õé£ÕüúÚì®þâÿµ╣░µÀçÔäâõ╝à
     */
    private JSONObject extractNodeBasicInfo(JSONObject node) {
        JSONObject info = new JSONObject();
        if (node == null) return info;
        info.put("id", node.getString("id"));
        info.put("label", node.getString("label"));
        info.put("code", node.getString("code"));
        info.put("weight", node.getBigDecimal("weight"));
        info.put("score", node.getBigDecimal("score"));
        info.put("calculatedValue", node.getBigDecimal("calculatedValue"));
        return info;
    }

    /**
     * ÚÄ╗µä¼Õ¢çÚæ║Õé£ÕüúÚùâÕáØÔé¼ÕÑ©ÕÄñþ╝â?     */
    private JSONObject extractThresholds(JSONObject node) {
        if (node == null) return null;
        JSONObject thresholds = new JSONObject();

        // µÁáÕÀåomputeRuleµÂô¯àí¯ç░ÚìÖµá¡µºçÚìèÕÑ©ÕÄñþ╝â?        JSONObject computeRule = node.getJSONObject("computeRule");
        if (computeRule != null) {
            JSONObject config = computeRule.getJSONObject("config");
            if (config != null) {
                // þö»µ¡î¯ØåÚÉ¿Õï»µºçÚìèþàÄþôºÕ¿ê?                if (config.containsKey("threshold")) {
                    thresholds.put("threshold", config.getBigDecimal("threshold"));
                }
                if (config.containsKey("minValue")) {
                    thresholds.put("min", config.getBigDecimal("minValue"));
                }
                if (config.containsKey("maxValue")) {
                    thresholds.put("max", config.getBigDecimal("maxValue"));
                }
                if (config.containsKey("targetValue")) {
                    thresholds.put("target", config.getBigDecimal("targetValue"));
                }
            }
        }

        // µÁáÕÀÿypeÚì£Õ«╝hresholdsþÇøµÑü¯åîþÆçÞ»▓Õ¢ç
        String type = node.getString("type");
        if (type != null) {
            thresholds.put("type", type);
        }

        return thresholds.isEmpty() ? null : thresholds;
    }

    /**
     * ÚÅïÕï½þ╝ôÚÄ©Õø¿þêúÕº╣Õø¿Ôé¼µÿÅÒÇâÚöøÕáóµòñµÁ£Õ║óÕºñÚìøÕ®üÞàæÚÉ¿Õï¼þ£╣ÚÄ¼µÿÅÒÇâÚÅìþàÄþØìþ╗Çþî┤þ┤Ü
     */
    private JSONArray buildIndicatorSummaryTable(JSONArray flatNodes) {
        JSONArray table = new JSONArray();
        if (flatNodes == null) return table;

        for (int i = 0; i < flatNodes.size(); i++) {
            JSONObject node = flatNodes.getJSONObject(i);
            JSONObject row = new JSONObject();

            row.put("level", node.getInteger("level"));
            row.put("indicatorName", node.getString("label"));
            row.put("indicatorCode", node.getString("code"));
            row.put("weight", node.getBigDecimal("weight"));
            row.put("score", node.getBigDecimal("score"));
            row.put("calculatedValue", node.getBigDecimal("calculatedValue"));
            row.put("isLeaf", node.getBoolean("isLeaf"));

            // ÚÅìÞºäÕÁüþü×Õé£Ú¬çþÆüÕëºþûåþ╝éÔòäþ╣ÿÚÅìÕø¬þÿæ
            int level = node.getInteger("level") != null ? node.getInteger("level") : 0;
            StringBuilder indent = new StringBuilder();
            for (int j = 0; j < level; j++) {
                indent.append("ÚèåÔé¼");  // ÚìÅÒä¿¯Øùþ╗îþâÿþë©þ╝éÔòäþ╣ÿ
            }
            row.put("indentedName", indent + node.getString("label"));

            table.add(row);
        }

        return table;
    }

    /**
     * ÚÅïÕï½þ╝ôþ╝üµØæÕ«│Õ»░µÑÇÕ×ÄÕº╣Õø¿Ôé¼?     */
    private JSONObject buildDimensionSummary(JSONObject tree, JSONObject finalResult) {
        JSONObject summary = new JSONObject();

        // þ╝üþàÄµéÄÕ»░µÑÇÕ×Ä
        summary.put("overallScore", finalResult.getBigDecimal("score"));
        summary.put("overallGrade", finalResult.getString("grade"));

        // µÂôÔé¼þ╗¥ÐàµÀ«µÉ┤´╣ÇþÀ▒ÚìÆ?        JSONArray dimensions = new JSONArray();
        if (tree != null) {
            JSONArray children = tree.getJSONArray("children");
            if (children != null) {
                for (int i = 0; i < children.size(); i++) {
                    JSONObject dim = children.getJSONObject(i);
                    JSONObject dimData = new JSONObject();
                    dimData.put("name", dim.getString("label"));
                    dimData.put("score", dim.getBigDecimal("score"));
                    dimData.put("weight", dim.getBigDecimal("weight"));

                    // þÆü´╝äþò╗þÆçÒâºµÀ«µÉ┤´©┐þ¼àÚÉ¿Õï½Õ¢¥þÇøµä»Õª¡ÚÉÉÞºäµÜƒ
                    int leafCount = countLeafNodes(dim);
                    dimData.put("indicatorCount", leafCount);

                    dimensions.add(dimData);
                }
            }
        }
        summary.put("dimensions", dimensions);

        return summary;
    }

    /**
     * þ╝üþå╗¯à©Úæ║Õé£ÕüúÚÉ¿Õï½Õ¢¥þÇøµä»Õª¡ÚÉÉÞºäµÜƒÚû▓?     */
    private int countLeafNodes(JSONObject node) {
        if (node == null) return 0;
        JSONArray children = node.getJSONArray("children");
        if (children == null || children.isEmpty()) {
            return 1;  // ÚÅê¯äâÚƒ®ÚÅä¯êÜÕ¢¥þÇøµä»Õª¡ÚÉÉ?        }
        int count = 0;
        for (int i = 0; i < children.size(); i++) {
            count += countLeafNodes(children.getJSONObject(i));
        }
        return count;
    }

    /**
     * ÚÅïÕï½þ╝ôÚìÖÞÀ║þôÖÚæ║Õé£ÕüúþÆç´©¥þ▓ÅþÆçÕï¬ÕÅèÚÅüþëêÕÁü
     */
    private JSONArray buildLeafEvaluationDetails(JSONArray leafNodes) {
        JSONArray details = new JSONArray();
        if (leafNodes == null) return details;

        for (int i = 0; i < leafNodes.size(); i++) {
            JSONObject leaf = leafNodes.getJSONObject(i);
            JSONObject detail = new JSONObject();

            detail.put("indicatorName", leaf.getString("label"));
            detail.put("indicatorCode", leaf.getString("code"));
            detail.put("score", leaf.getBigDecimal("score"));
            detail.put("weight", leaf.getBigDecimal("weight"));
            detail.put("calculatedValue", leaf.getBigDecimal("calculatedValue"));

            // þÆçÕï¬ÕÅèþ╝üµÆ╣¯åæÚöøÕáØþåÇµÁ£Õ║íþÀ▒ÚìÆÕù¡þ┤Ü
            BigDecimal score = leaf.getBigDecimal("score");
            String conclusion = evaluateScore(score);
            detail.put("evaluationConclusion", conclusion);

            // ÚùâÕáØÔé¼Úù┤õ┐èÚÄ¡?            JSONObject thresholds = leaf.getJSONObject("thresholds");
            if (thresholds != null) {
                detail.put("thresholdRange", thresholds);
            }

            details.add(detail);
        }

        return details;
    }

    /**
     * ÚÅìÞºäÕÁüÕ»░µÑÇÕ×ÄþÆçÕï¬ÕÅèþ╝üµÆ╣¯åæ
     */
    private String evaluateScore(BigDecimal score) {
        if (score == null) return "ÚÅê¯üçþÿÄµÁ╝?;
        if (score.compareTo(new BigDecimal("90")) >= 0) return "µÁ╝µ¿╝¯Øà";
        if (score.compareTo(new BigDecimal("75")) >= 0) return "Úæ╣¯êÜÒé¢";
        if (score.compareTo(new BigDecimal("60")) >= 0) return "ÚìÜÕáƒþë©";
        return "ÚùçÔé¼ÚÅÇþíàþ╣ÿ";
    }

    /**
     * Úæ¥Õ│░Õ¢çµÁáÞ»▓Õºƒþü×þé┤Ôé¼ÐâÔé¼?     */
    private Object getTaskPropertyValue(String propertyName, CalcTask task) {
        if (task == null || propertyName == null) return null;
        switch (propertyName) {
            case "taskName":
                return task.getTaskName();
            case "startTime":
                return task.getStartTime();
            case "endTime":
                return task.getEndTime();
            case "evaluateTarget":
                return task.getAssessTaskId();
            case "conclusion":
                return task.getResultSummaryJson();
            default:
                return null;
        }
    }

    private EvalResult buildEvalResult(CalcTask task,
                                       CalcFlowTemplate template,
                                       EvalIndicatorSystem indicatorSystem,
                                       JSONObject finalResult,
                                       JSONObject reportDataContext,
                                       Map<String, Object> stageContext,
                                       JSONObject reportConfig) {
        EvalResult evalResult = new EvalResult();
        evalResult.setTaskId(task.getId());
        evalResult.setTaskName(task.getTaskName());
        evalResult.setTemplateId(template.getId());
        evalResult.setTemplateName(template.getTemplateName());
        if (indicatorSystem != null) {
            evalResult.setIndicatorSystemId(indicatorSystem.getId());
            evalResult.setIndicatorSystemName(indicatorSystem.getSystemName());
        }
        evalResult.setScore(readBigDecimal(finalResult, "score"));
        evalResult.setGrade(finalResult.getString("grade"));
        evalResult.setConclusion(finalResult.getString("conclusion"));
        evalResult.setSuggestion(finalResult.getString("suggestion"));
        // Õ¿┤õ¢╣µîëþ╗¥Þâ»ÕÜ£ÚìöÒä¿µâñµÉ┤µôäþ┤░þÆü´╝äþò╗Õ«©µÅÆþò¼ÚÄ┤µäÂþ┤ØµØ®µÂÿÕÅåÚèåÕ▓â¯à©þ╗áµñ¥Ú¬çÚìæµüÆÔé¼ÕÂåÔé¼õ¥èþ┤ØµÂôÕ║Øµ▒ëÕ«©ÒâÑþÂìÚìÅÒâºµ«æ PENDING ÚìûÕôäÕ×Ä
        evalResult.setWorkflowStatus("GATHERING");
        evalResult.setCreateBy(SecurityUtils.getUsername());
        evalResult.setCreateTime(new Date());

        JSONObject reportPayload = new JSONObject();
        reportPayload.put("outputTargets", reportConfig != null ? reportConfig.getJSONArray("outputTargets") : null);
        reportPayload.put("reportTemplateId", reportConfig != null ? reportConfig.getLong("reportTemplateId") : null);
        reportPayload.put("reportDataContext", reportDataContext);
        if (stageContext != null && stageContext.get("executionChain") != null) {
            reportPayload.put("executionChain", stageContext.get("executionChain"));
        }
        if (stageContext != null && stageContext.get("comprehensiveDispatchChannel") != null) {
            reportPayload.put("comprehensiveDispatchChannel", stageContext.get("comprehensiveDispatchChannel"));
        }
        evalResult.setReportPayloadJson(reportPayload.toJSONString());

        List<EvalResult.DimensionScore> dimensionScores = new ArrayList<>();
        JSONArray dimensions = finalResult != null ? finalResult.getJSONArray("dimensions") : null;
        if (dimensions != null) {
            for (int i = 0; i < dimensions.size(); i++) {
                JSONObject one = dimensions.getJSONObject(i);
                EvalResult.DimensionScore dimensionScore = new EvalResult.DimensionScore();
                dimensionScore.setLabel(one.getString("label"));
                dimensionScore.setValue(readBigDecimal(one, "value"));
                dimensionScore.setTone(one.getString("tone"));
                dimensionScores.add(dimensionScore);
            }
        }
        evalResult.setDimensionList(dimensionScores);
        return evalResult;
    }

    private boolean containsTarget(JSONArray outputTargets, String target) {
        if (outputTargets == null || outputTargets.isEmpty()) {
            return "RESULT_DB".equals(target);
        }
        for (int i = 0; i < outputTargets.size(); i++) {
            if (target.equals(outputTargets.getString(i))) {
                return true;
            }
        }
        return false;
    }

    private BigDecimal readBigDecimal(JSONObject object, String key) {
        if (object == null || object.getBigDecimal(key) == null) {
            return BigDecimal.ZERO;
        }
        return object.getBigDecimal(key);
    }

    private CalcTaskStageLog buildStageLog(CalcTask task, JSONObject stage, String executeStatus) {
        Objects.requireNonNull(stage, "stage config is required");
        CalcTaskStageLog log = new CalcTaskStageLog();
        log.setCalcTaskId(task.getId());
        log.setStageCode(stage.getString("stageCode"));
        log.setStageName(stage.getString("stageName"));
        log.setStageOrder(stage.getInteger("stageOrder"));
        log.setExecuteStatus(executeStatus);
        log.setBeginTime(new Date());
        return log;
    }

    private void updateTaskProgress(CalcTask task, String currentStage, int progress) {
        task.setCurrentStage(currentStage);
        task.setProgressPercent(progress);
        task.setUpdateBy(SecurityUtils.getUsername());
        task.setUpdateTime(new Date());
        baseMapper.updateById(task);
    }

    private JSONObject parseConfig(String configJson) {
        try {
            return JSON.parseObject(configJson);
        } catch (Exception ex) {
            throw new ServiceException("template configJson is invalid");
        }
    }

    private JSONObject stageConfig(JSONObject stage) {
        if (stage == null) {
            return new JSONObject();
        }
        JSONObject config = stage.getJSONObject("config");
        return config == null ? new JSONObject() : config;
    }

    private String buildTaskName(CalcFlowTemplate template) {
        return template.getTemplateName() + "-" + System.currentTimeMillis();
    }

    /**
     * ÚÄ©ÕñïþÑªþ╗ïÕ¼½─üÚÅë?reportTemplateId Õ¿ôÕÅëþàï HTML Ú¬×µ£Áþ¼éµÁ╝þè│µ×âµÁáÞêÁµ╣çÚìöÔÿàþ┤ÖMinIOÚöøÕñøþ┤ØþÆ║¯êÜþÀ×ÚìÉµ¼ÅÕÅå {@link EvalResult#setReportUrl}Úèå?     */
    private void tryUploadEvalReportToMinio(EvalResult evalResult, CalcTask task, JSONObject reportConfig,
                                            JSONObject reportDataContext) {
        Long tmplId = reportConfig == null ? null : reportConfig.getLong("reportTemplateId");
        if (tmplId == null || tmplId <= 0) {
            log.info("ÚÅê¯üêÕÄñþ╝â?reportTemplateIdÚöøÕ▓âþâªµØ®?HTML ÚÄÂÒâÑµåíÕ¿ôÕÅëþàïµÂôÕ║óµ×âµÁáµ£Áþ¼éµÁ╝þïàþ┤ÖþÆçÕï¬ÕÅèþ╝üµÆ┤þüëµÁáÕÂäþ┤░ÚÆÇÞùëþ░▒Úöø? calcTaskId={}", task.getId());
            return;
        }
        ReportTemplateRenderRequest rr = new ReportTemplateRenderRequest();
        rr.setFields(jsonObjectToFreemarkerModel(reportDataContext));
        ReportDownloadData html = reportTemplateService.renderHtmlDownload(tmplId, rr);
        String path = evalReportFileStorageService.uploadEvalReport(
                task.getId(), evalResult.getResultCode(), "html", html.getBytes());
        evalResult.setReportUrl(path);
        log.info("þÆçÕï¬ÕÅèÚÄÂÒâÑµåíÕ«©Þ╣¡þ¼éµÁ╝? calcTaskId={}, templateId={}, path={}", task.getId(), tmplId, path);
    }

    private void mergeReportPayloadNote(EvalResult evalResult, String key, String value) {
        if (evalResult == null || StringUtils.isBlank(key)) {
            return;
        }
        try {
            JSONObject p = StringUtils.isBlank(evalResult.getReportPayloadJson())
                    ? new JSONObject()
                    : JSON.parseObject(evalResult.getReportPayloadJson());
            p.put(key, value);
            evalResult.setReportPayloadJson(p.toJSONString());
        } catch (Exception ex) {
            log.debug("mergeReportPayloadNote skipped: {}", ex.getMessage());
        }
    }

    private Map<String, Object> jsonObjectToFreemarkerModel(JSONObject o) {
        Map<String, Object> m = new LinkedHashMap<>();
        if (o == null) {
            return m;
        }
        for (String k : o.keySet()) {
            m.put(k, jsonValueToModel(o.get(k)));
        }
        return m;
    }

    private Object jsonValueToModel(Object v) {
        if (v instanceof JSONObject) {
            return jsonObjectToFreemarkerModel((JSONObject) v);
        }
        if (v instanceof JSONArray) {
            return jsonArrayToModelList((JSONArray) v);
        }
        return v;
    }

    private List<Object> jsonArrayToModelList(JSONArray arr) {
        List<Object> list = new ArrayList<>();
        if (arr == null) {
            return list;
        }
        for (int i = 0; i < arr.size(); i++) {
            list.add(jsonValueToModel(arr.get(i)));
        }
        return list;
    }
}
